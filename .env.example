NODE_ENV=development

# Public URLs
PUBLIC_WEB_BASE_URL=https://checklove.babyress.games
PUBLIC_API_BASE_URL=https://api.checklove.babyress.games
PUBLIC_ADMIN_BASE_URL=https://admin.checklove.babyress.games
VITE_API_BASE_URL=https://api.checklove.babyress.games/api
VITE_PUSH_PUBLIC_KEY=
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://checklove.babyress.games,https://admin.checklove.babyress.games

# API
PORT=4000
JWT_SECRET=change-me-with-a-long-random-secret
MONGODB_URI=mongodb://mongo:27017/lovecheck
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=10

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Mail OTP. For Gmail, use an App Password, not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=hello.couple@gmail.com
SMTP_PASS=change-me-gmail-app-password
MAIL_FROM="LoveCheck <hello.couple@gmail.com>"
OTP_TTL_MINUTES=10
REQUIRE_LOGIN_OTP=false

# Optional Web Push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
